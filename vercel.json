{
  "version": 2,
  "builds": [
    {
      "src": "app/**/*.{js,ts,jsx,tsx,mdx}",
      "use": "@vercel/next"
    },
    {
      "src": "app/api/**/*.{js,ts,jsx,tsx}",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "OPENAI_API_KEY": "@openai-api-key",
    "ANTHROPIC_API_KEY": "@anthropic-api-key"
  }
}
